generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model assessment_attempts {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id String?      @db.Uuid
  student_id    String?      @db.Uuid
  score         Decimal?     @db.Decimal
  answers       Json?
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  assessments   assessments? @relation(fields: [assessment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students      students?    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([assessment_id])
  @@index([student_id])
  @@schema("app")
}

model assessments {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String?
  subject_id           String?
  curriculum_id        String?
  metadata             Json?
  created_by           String?                @db.Uuid
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  assessment_attempts  assessment_attempts[]
  assessment_questions assessment_questions[]
  users                users?                 @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  curricula            curricula?             @relation(fields: [curriculum_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects             subjects?              @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by])
  @@index([curriculum_id])
  @@index([subject_id])
  @@schema("app")
}

model audit_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_user_id String?   @db.Uuid
  action        String?
  object_type   String?
  object_id     String?
  details       Json?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  users         users?    @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([actor_user_id])
  @@schema("app")
}

model bookings {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id              String?      @db.Uuid
  package_id              String?      @db.Uuid
  subject_id              String?
  curriculum_id           String?
  requested_start         DateTime?    @db.Timestamptz(6)
  requested_end           DateTime?    @db.Timestamptz(6)
  status                  String?
  assigned_tutor_id       String?      @db.Uuid
  note                    String?
  created_at              DateTime?    @default(now()) @db.Timestamptz(6)
  program_id              String?      @db.Uuid
  credit_cost             Int          @default(0)
  is_free_session         Boolean      @default(false)
  is_trial_session        Boolean      @default(false)
  enrollment_id           String?      @db.Uuid
  series_id               String?      @db.Uuid
  fallback_broadcasted_at DateTime?    @db.Timestamptz(6)
  tutors                  tutors?      @relation(fields: [assigned_tutor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  curricula               curricula?   @relation(fields: [curriculum_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  enrollment              enrollments? @relation(fields: [enrollment_id], references: [id])
  packages                packages?    @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  program                 Program?     @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students                students?    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects                subjects?    @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sessions                sessions[]

  @@index([student_id])
  @@index([assigned_tutor_id])
  @@index([package_id])
  @@index([program_id])
  @@index([curriculum_id])
  @@index([subject_id])
  @@index([enrollment_id])
  @@index([status])
  @@index([requested_start])
  @@index([status, requested_start])
  @@index([series_id])
  @@schema("app")
}

model curricula {
  id                     String                   @id
  name                   String
  country                String?
  description            String?
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  assessments            assessments[]
  assignments            assignments[]
  bookings               bookings[]
  curriculum_subject_map curriculum_subject_map[]
  progress_points        progress_points[]
  students               students[]

  @@schema("app")
}

model curriculum_subject_map {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curriculum_id String?
  subject_id    String?
  external_code String?
  curricula     curricula? @relation(fields: [curriculum_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects      subjects?  @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([curriculum_id])
  @@index([subject_id])
  @@schema("app")
}

model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  type       String?
  payload    Json?
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@index([user_id, is_read])
  @@schema("app")
}

model package_items {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  package_id String?   @db.Uuid
  subject_id String?
  hours      Int?
  note       String?
  packages   packages? @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects   subjects? @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([package_id])
  @@index([subject_id])
  @@schema("app")
}

model packages {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  price_cents    Int?
  currency       String?         @default("USD")
  billing_type   String?
  active         Boolean?        @default(true)
  created_at     DateTime?       @default(now()) @db.Timestamptz(6)
  base_price_usd Int?
  bookings       bookings[]
  package_items  package_items[]
  purchases      purchases[]
  students       students[]
  user_credits   user_credits[]

  @@schema("app")
}

model progress_points {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id     String?    @db.Uuid
  curriculum_id  String?
  objective_code String?
  mastery_level  String?
  last_updated   DateTime?  @default(now()) @db.Timestamptz(6)
  curricula      curricula? @relation(fields: [curriculum_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students       students?  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([student_id])
  @@index([curriculum_id])
  @@schema("app")
}

model purchases {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String?   @db.Uuid
  package_id            String?   @db.Uuid
  amount_cents          Int?
  currency              String?   @default("USD")
  status                String?   @default("PENDING")
  payment_provider      String?
  payment_provider_id   String?
  razorpay_order_id     String?   @unique
  razorpay_payment_id   String?   @unique
  razorpay_signature    String?
  payment_method        String?
  payment_method_detail Json?
  failure_reason        String?
  refund_id             String?
  refunded_at           DateTime? @db.Timestamptz(6)
  verified_at           DateTime? @db.Timestamptz(6)
  ip_address            String?
  user_agent            String?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  program_id            String?   @db.Uuid
  credit_granted_at     DateTime? @db.Timestamptz(6)
  packages              packages? @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  program               Program?  @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                 users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@index([package_id])
  @@index([program_id])
  @@index([status])
  @@schema("app")
}

model webhook_events {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id     String    @unique
  event_type   String
  payload      Json
  processed    Boolean   @default(false)
  processed_at DateTime? @db.Timestamptz(6)
  error        String?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)

  @@map("webhook_events")
  @@schema("app")
}

model user_credits {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @db.Uuid
  package_id        String?   @db.Uuid
  credits_total     Int       @default(0)
  credits_used      Int       @default(0)
  credits_remaining Int       @default(0)
  reset_date        DateTime  @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @updatedAt @db.Timestamptz(6)
  packages          packages? @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@index([package_id])
  @@map("user_credits")
  @@schema("app")
}

model credit_usage_logs {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  session_id   String?   @db.Uuid
  credits_used Int       @default(1)
  used_at      DateTime  @default(now()) @db.Timestamptz(6)
  notes        String?
  sessions     sessions? @relation(fields: [session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@index([session_id])
  @@map("credit_usage_logs")
  @@schema("app")
}

model session_recordings {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id       String?   @db.Uuid
  uploaded_by      String?   @db.Uuid
  file_url         String?
  storage_path     String?
  file_size_bytes  Int?
  duration_seconds Int?
  transcript       String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  auto_delete_at   DateTime? @db.Timestamptz(6)
  azure_blob_name  String?
  last_viewed_at   DateTime? @db.Timestamptz(6)
  view_count       Int       @default(0)
  mime_type        String?
  sessions         sessions? @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?    @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([session_id])
  @@index([uploaded_by])
  @@schema("app")
}

// A paid student's request to reschedule a pre-scheduled class. Admin actions it
// (approve → reschedule via existing tools, or decline). Display fields are
// snapshotted at request time so the admin queue needs no joins and stays accurate
// even if the underlying session changes.
model reschedule_requests {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id      String?   @db.Uuid
  student_id      String?   @db.Uuid
  requested_by    String?   @db.Uuid
  student_name    String?
  subject         String?
  class_time      DateTime? @db.Timestamptz(6)
  reason          String?
  preferred_slots String?
  status          String    @default("pending") // pending | approved | declined
  admin_note      String?
  handled_by      String?   @db.Uuid
  handled_at      DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([student_id])
  @@index([status])
  @@schema("app")
}

model sessions {
  id                      String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id              String?              @db.Uuid
  start_time              DateTime?            @db.Timestamptz(6)
  end_time                DateTime?            @db.Timestamptz(6)
  meet_link               String?
  whiteboard_link         String?
  video_provider          VideoProvider?       @default(DAILYCO)
  zoom_meeting_id         String?
  zoom_join_url           String?
  status                  String?
  recordingRequired       Boolean?             @default(true) @map("recording_required")
  recordingUploaded       Boolean?             @default(false) @map("recording_uploaded")
  reviewedByAdmin         Boolean?             @default(false) @map("reviewed_by_admin")
  flagged                 Boolean?             @default(false)
  created_at              DateTime?            @default(now()) @db.Timestamptz(6)
  duration                Int?                 @default(45)
  program_id              String?              @db.Uuid
  attention_status        String?
  attention_meta          Json?
  current_phase           SessionPhase         @default(WARM_CONNECT)
  phase_history           Json?
  pedagogy_status         String?
  tutor_note              String?
  whiteboard_snapshot_url String?
  attendance              Attendance[]
  attention_events        AttentionEvent[]
  class_notes             class_notes[]
  credit_usage_logs       credit_usage_logs[]
  session_messages        session_messages[]
  session_recordings      session_recordings[]
  bookings                bookings?            @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  program                 Program?             @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sticker_rewards         sticker_rewards[]
  tutor_ratings           tutor_ratings?

  @@index([booking_id])
  @@index([program_id])
  @@index([status])
  @@index([start_time])
  @@index([status, start_time])
  @@schema("app")
}

model students {
  id                                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                              String?               @unique @db.Uuid
  email                                String?               @unique
  first_name                           String?
  last_name                            String?
  parent_user_id                       String?               @db.Uuid
  grade                                String?
  school                               String?
  birth_date                           DateTime?             @db.Date
  curriculum_preference                String?
  interests                            Json?
  recent_focus                         String?
  struggle_areas                       Json?
  created_at                           DateTime?             @default(now()) @db.Timestamptz(6)
  program_id                           String?               @db.Uuid
  is_trial_active                      Boolean               @default(true)
  subscription_credits                 Int                   @default(0)
  subscription_ends                    DateTime?             @db.Timestamptz(6)
  subscription_plan                    String?               @db.VarChar(20)
  subscription_starts                  DateTime?             @db.Timestamptz(6)
  trial_credits                        Int                   @default(120)
  trial_expires_at                     DateTime?             @db.Timestamptz(6)
  trial_sessions_used                  Int                   @default(0)
  trial_started_at                     DateTime?             @db.Timestamptz(6)
  enrollment_status                    String                @default("trial")
  package_end_date                     DateTime?             @db.Timestamptz(6)
  practice_xp                          Int                   @default(0)
  practice_streak                      Int                   @default(0)
  last_practice_at                     DateTime?             @db.Timestamptz(6)
  sessions_remaining                   Int                   @default(0)
  badges                               String[]              @default([])
  last_session_week                    String?
  streak_weeks                         Int                   @default(0)
  total_hours_learned                  Float                 @default(0)
  trial_tutor_id                       String?               @db.Uuid
  package_id                           String?               @db.Uuid
  exam_board                           String?
  target_grade                         String?
  exam_date                            DateTime?             @db.Date
  target_exam                          String?
  // Verifiable parental consent to record this child's live sessions.
  // Captured once at onboarding (required prompt) and toggleable from
  // Profile → Settings. Sessions may still run live without it, but no
  // recording is produced or shared until granted. COPPA/GDPR-K/DPDP.
  recording_consent_granted            Boolean               @default(false)
  recording_consent_at                 DateTime?             @db.Timestamptz(6)
  recording_consent_version            String?
  recording_consent_by                 String?               @db.Uuid
  assessment_attempts                  assessment_attempts[]
  attendance                           Attendance[]
  bookings                             bookings[]
  credit_adjustments                   credit_adjustments[]
  enrollments                          enrollments[]
  progress_points                      progress_points[]
  curricula                            curricula?            @relation(fields: [curriculum_preference], references: [id], onDelete: NoAction, onUpdate: NoAction)
  packages                             packages?             @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_students_parent_user_idTousers users?                @relation("students_parent_user_idTousers", fields: [parent_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  program                              Program?              @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trial_tutor                          tutors?               @relation("trial_tutor", fields: [trial_tutor_id], references: [id])
  users_students_user_idTousers        users?                @relation("students_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  submissions                          submissions[]
  tutor_messages                       tutor_messages[]

  @@index([parent_user_id])
  @@index([program_id])
  @@index([package_id])
  @@index([trial_tutor_id])
  @@index([subscription_ends])
  @@schema("app")
}

model subjects {
  id                     String                   @id
  name                   String
  canonical_code         String?                  @unique
  description            String?
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  assessments            assessments[]
  assignments            assignments[]
  bookings               bookings[]
  curriculum_subject_map curriculum_subject_map[]
  package_items          package_items[]

  @@schema("app")
}

model tutor_shifts {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutor_id    String?   @db.Uuid
  day_of_week Int?      @db.SmallInt
  start_time  DateTime? @db.Time(6)
  end_time    DateTime? @db.Time(6)
  timezone    String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  tutors      tutors?   @relation(fields: [tutor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tutor_id])
  @@schema("app")
}

model tutors {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String           @db.Uuid
  bio                String?
  qualifications     Json?
  skills             Json?
  hourly_rate_cents  Int?
  employment_type    String?
  is_active          Boolean?         @default(true)
  tutor_approved     Boolean          @default(false)
  tutor_review_notes String?
  created_at         DateTime?        @default(now()) @db.Timestamptz(6)
  program_id         String?          @db.Uuid
  last_seen          DateTime?        @db.Timestamptz(6)
  bookings           bookings[]
  enrollments        enrollments[]
  trial_students     students[]       @relation("trial_tutor")
  tutor_messages     tutor_messages[]
  tutor_ratings      tutor_ratings[]
  tutor_shifts       tutor_shifts[]
  program            Program?         @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([program_id])
  @@schema("app")
}

model users {
  id                                      String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                   String               @unique
  password_hash                           String?
  role                                    String
  first_name                              String?
  last_name                               String?
  phone                                   String?              @unique
  timezone                                String?              @default("UTC")
  is_active                               Boolean?             @default(true)
  email_verified                          Boolean              @default(false)
  force_password_change                   Boolean              @default(false)
  email_verification_token                String?
  email_verification_expires              DateTime?            @db.Timestamptz(6)
  tutor_invite_token                      String?
  tutor_invite_expires                    DateTime?            @db.Timestamptz(6)
  created_at                              DateTime?            @default(now()) @db.Timestamptz(6)
  parent_id                               String?              @db.Uuid
  referred_by                             String?              @db.Uuid
  school_id                               String?              @db.Uuid
  tutor_status                            TutorStatus          @default(ACTIVE)
  phone_verified                          Boolean              @default(false)
  last_login_at                           DateTime?            @db.Timestamptz(6)
  email_opted_out                         Boolean              @default(false)
  lead_source                             String?
  onboarding_status                       String               @default("not_started")
  assessments                             assessments[]
  assignments                             assignments[]
  student_attention_events                AttentionEvent[]     @relation("StudentAttentionEvents")
  tutor_attention_events                  AttentionEvent[]     @relation("TutorAttentionEvents")
  audit_logs                              audit_logs[]
  blog_versions                           blog_versions[]
  blogs                                   blogs[]
  class_notes                             class_notes[]
  credit_adjustments                      credit_adjustments[]
  credit_usage_logs                       credit_usage_logs[]
  notifications                           notifications[]
  purchases                               purchases[]
  session_messages                        session_messages[]
  session_recordings                      session_recordings[]
  sticker_rewards                         sticker_rewards[]
  students_students_parent_user_idTousers students[]           @relation("students_parent_user_idTousers")
  users_students_user_idTousers           students?            @relation("students_user_idTousers")
  support_tickets                         support_tickets[]
  tutor_messages                          tutor_messages[]
  tutor_ratings                           tutor_ratings[]
  tutors                                  tutors[]
  user_credits                            user_credits[]
  parent                                  users?               @relation("ParentChildren", fields: [parent_id], references: [id])
  children                                users[]              @relation("ParentChildren")
  referrer                                users?               @relation("UserReferrals", fields: [referred_by], references: [id], onDelete: SetNull, onUpdate: NoAction)
  referrals                               users[]              @relation("UserReferrals")
  school                                  School?              @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([parent_id])
  @@index([referred_by])
  @@index([school_id])
  @@index([role])
  @@index([role, is_active])
  @@schema("app")
}

model credit_adjustments {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id String   @db.Uuid
  amount     Int
  note       String?
  granted_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [granted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students   students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([student_id])
  @@index([granted_by])
  @@schema("app")
}

model session_messages {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id String?   @db.Uuid
  user_id    String?   @db.Uuid
  text       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  sessions   sessions? @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([session_id])
  @@index([user_id])
  @@schema("app")
}

model blogs {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  slug             String          @unique
  excerpt          String
  content          String
  image_url        String
  category         String
  status           String          @default("PENDING")
  author_id        String          @db.Uuid
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?       @updatedAt @db.Timestamptz(6)
  image_alt        String?
  published_at     DateTime?       @db.Timestamptz(6)
  related_blog_ids String[]        @default([])
  seo_description  String?
  seo_title        String?
  target_keyword   String?
  versions         blog_versions[]
  users            users           @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([author_id])
  @@index([status, published_at])
  @@index([created_at])
  @@schema("app")
}

model blog_versions {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blog_id          String   @db.Uuid
  title            String
  excerpt          String
  content          String
  image_url        String
  category         String
  image_alt        String?
  summary          String?
  author_id        String   @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  related_blog_ids String[] @default([])
  seo_description  String?
  seo_title        String?
  target_keyword   String?
  author           users    @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blog             blogs    @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([blog_id])
  @@index([author_id])
  @@schema("app")
}

model Program {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  status      String
  startDate   DateTime      @map("start_date") @db.Timestamptz(6)
  endDate     DateTime      @map("end_date") @db.Timestamptz(6)
  academic    Json
  operational Json
  financial   Json
  staffing    Json
  delivery    Json
  reporting   Json
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  schoolId    String?       @map("school_id") @db.Uuid
  bookings    bookings[]
  enrollments enrollments[]
  school      School?       @relation(fields: [schoolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchases   purchases[]
  sessions    sessions[]
  students    students[]
  tutors      tutors[]

  @@map("programs")
  @@schema("app")
}

model District {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name    String
  schools School[]

  @@map("districts")
  @@schema("app")
}

model School {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  districtId String?   @map("district_id") @db.Uuid
  programs   Program[]
  district   District? @relation(fields: [districtId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users[]

  @@map("schools")
  @@schema("app")
}

model Attendance {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  studentId       String    @map("student_id") @db.Uuid
  present         Boolean   @default(false)
  markedByTutor   Boolean   @default(false) @map("marked_by_tutor")
  minutesAttended Int?      @map("minutes_attended")
  joinedAt        DateTime? @map("joined_at") @db.Timestamptz(6)
  leftAt          DateTime? @map("left_at") @db.Timestamptz(6)
  sessions        sessions  @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students        students  @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sessionId, studentId])
  @@map("attendance")
  @@schema("app")
}

model AttentionEvent {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String             @map("session_id") @db.Uuid
  studentId String             @map("student_id") @db.Uuid
  tutorId   String             @map("tutor_id") @db.Uuid
  type      AttentionEventType
  timestamp DateTime           @default(now()) @db.Timestamptz(6)
  metadata  Json?
  Session   sessions           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  Student   users              @relation("StudentAttentionEvents", fields: [studentId], references: [id], onDelete: Cascade)
  Tutor     users              @relation("TutorAttentionEvents", fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([studentId])
  @@index([tutorId])
  @@map("attention_events")
  @@schema("app")
}

model enrollments {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id      String     @db.Uuid
  program_id      String     @db.Uuid
  tutor_id        String?    @db.Uuid
  schedule_preset String
  schedule_days   Int[]
  start_time      String
  duration        Int        @default(60)
  subject_ids     String[]
  curriculum_id   String?
  package_id      String?    @db.Uuid
  status          String
  started_at      DateTime   @default(now()) @db.Timestamptz(6)
  ended_at        DateTime?  @db.Timestamptz(6)
  pause_until     DateTime?  @db.Timestamptz(6)
  schedule_source String     @default("auto")
  auto_assign     Boolean    @default(true)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  bookings        bookings[]
  program         Program    @relation(fields: [program_id], references: [id], onDelete: NoAction)
  students        students   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  tutors          tutors?    @relation(fields: [tutor_id], references: [id], onDelete: NoAction)

  @@index([student_id])
  @@index([tutor_id])
  @@index([program_id])
  @@index([package_id])
  @@schema("app")
}

model sticker_rewards {
